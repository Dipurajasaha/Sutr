# ==========================================
# -- global environment variables --
# ==========================================
PROJECT_NAME=Sutr
ENVIRONMENT=development

# ==========================================
# -- database configuration --
# ==========================================
POSTGRES_USER=sutr_admin
POSTGRES_PASSWORD=sutr_password
POSTGRES_DB=sutr_db
# Note: Use localhost for local python running, but 'postgres' when running inside Docker
DATABASE_URL=postgresql+asyncpg://sutr_admin:sutr_password@localhost:5432/sutr_db

# ==========================================
# -- local storage & indexing paths --
# ==========================================
UPLOAD_DIR=./uploads
FAISS_INDEX_PATH=./faiss_store/index.bin

# ==========================================
# -- external APIs (Longcat) --
# ==========================================
# IMPORTANT: Do NOT commit your actual API key to git
# Add your real key to .env (which is in .gitignore)
LONGCAT_API_KEY=your_real_api_key_here
LONGCAT_BASE_URL=https://api.longcat.chat/openai/v1
LONGCAT_MODEL=LongCat-Flash-Chat

# ==========================================
# -- internal microservice routing --
# ==========================================
# Used by the API Gateway to route requests, and by the Chat Service to fetch chunks
UPLOAD_SERVICE_URL=http://localhost:8001
PROCESS_SERVICE_URL=http://localhost:8002
VECTOR_SERVICE_URL=http://localhost:8003
CHAT_SERVICE_URL=http://localhost:8004
SUMMARY_SERVICE_URL=http://localhost:8005
MEDIA_SERVICE_URL=http://localhost:8007
